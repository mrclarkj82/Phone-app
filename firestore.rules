rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasAllowedRole(role) {
      return role in ['student', 'teacher', 'admin'];
    }

    function accountPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function assignedAccount() {
      return get(accountPath()).data;
    }

    function hasAssignedActiveAccount() {
      return signedIn()
        && exists(accountPath())
        && assignedAccount().uid == request.auth.uid
        && assignedAccount().email == request.auth.token.email
        && assignedAccount().active == true
        && hasAllowedRole(assignedAccount().role);
    }

    function hasRole(role) {
      return hasAssignedActiveAccount() && assignedAccount().role == role;
    }

    function teacherOrAdmin() {
      return hasRole('teacher') || hasRole('admin');
    }

    function ownsAssignment(data) {
      return data.teacherUid is string && data.teacherUid == request.auth.uid;
    }

    function isClassTeacher(data) {
      return hasRole('teacher') && data.teacherUid == request.auth.uid;
    }

    function isClassStudent(data) {
      return hasRole('student')
        && data.studentUids is list
        && request.auth.uid in data.studentUids;
    }

    function validUserDocument(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'active'])
        && data.uid is string
        && data.email is string
        && data.displayName is string
        && data.active is bool
        && hasAllowedRole(data.role);
    }

    function isOwnEmail(data) {
      return signedIn() && data.email == request.auth.token.email;
    }

    function announcementTargetsRole(data) {
      return (hasRole('student') && data.targetAudience in ['students', 'both'])
        || (hasRole('teacher') && data.targetAudience in ['teachers', 'both']);
    }

    function canReadAnnouncement(data) {
      return hasRole('admin')
        || (
          hasAssignedActiveAccount()
          && data.active == true
          && data.archived != true
          && announcementTargetsRole(data)
        );
    }

    function validAnnouncement(data) {
      return data.keys().hasAll([
          'title',
          'body',
          'type',
          'priority',
          'targetAudience',
          'active',
          'startDate',
          'createdBy',
          'createdByEmail',
          'updatedAt',
          'archived'
        ])
        && data.title is string
        && data.body is string
        && data.type in [
          'general',
          'class-reminder',
          'assignment-reminder',
          'testing',
          'schedule-change',
          'important-alert',
          'video-announcement'
        ]
        && data.priority in ['normal', 'important', 'urgent']
        && data.targetAudience in ['students', 'teachers', 'both']
        && data.active is bool
        && data.archived is bool
        && data.startDate is timestamp
        && (data.endDate == null || data.endDate is timestamp)
        && data.createdBy is string
        && data.createdByEmail is string;
    }

    function ownsAnnouncementRead(data) {
      return hasAssignedActiveAccount()
        && data.userId is string
        && data.userId == request.auth.uid
        && data.userEmail is string
        && data.announcementId is string;
    }

    match /users/{userId} {
      // Google Auth may identify a user before the Firestore account check.
      // Only the already-assigned user record may be read during that check.
      allow get: if signedIn()
        && (userId == request.auth.uid || isOwnEmail(resource.data) || hasRole('admin'));
      allow list: if signedIn() && (isOwnEmail(resource.data) || hasRole('admin'));
      allow create, update: if hasRole('admin') && validUserDocument(request.resource.data);
      allow delete: if hasRole('admin');
    }

    match /assignments/{assignmentId} {
      allow read: if hasAssignedActiveAccount();
      allow create: if hasRole('admin')
        || (hasRole('teacher') && ownsAssignment(request.resource.data));
      allow update: if hasRole('admin')
        || (
          hasRole('teacher')
          && ownsAssignment(resource.data)
          && ownsAssignment(request.resource.data)
        );
      allow delete: if hasRole('admin')
        || (hasRole('teacher') && ownsAssignment(resource.data));
    }

    match /announcements/{announcementId} {
      allow read: if canReadAnnouncement(resource.data);
      allow create, update: if hasRole('admin') && validAnnouncement(request.resource.data);
      allow delete: if hasRole('admin');
    }

    match /announcementReads/{readId} {
      allow read: if hasRole('admin') || ownsAnnouncementRead(resource.data);
      allow create: if ownsAnnouncementRead(request.resource.data);
      allow update: if ownsAnnouncementRead(resource.data)
        && ownsAnnouncementRead(request.resource.data)
        && request.resource.data.announcementId == resource.data.announcementId;
      allow delete: if hasRole('admin') || ownsAnnouncementRead(resource.data);
    }

    match /teachers/{teacherId} {
      allow read: if hasRole('admin')
        || (hasRole('teacher') && resource.data.uid == request.auth.uid);
      allow create, update, delete: if hasRole('admin');
    }

    match /classes/{classId} {
      allow read: if hasRole('admin') || isClassTeacher(resource.data) || isClassStudent(resource.data);
      allow create, update, delete: if hasRole('admin');
    }

    match /submissions/{submissionId} {
      allow read: if hasAssignedActiveAccount()
        && (teacherOrAdmin() || resource.data.studentUid == request.auth.uid);
      allow create: if hasAssignedActiveAccount()
        && (
          teacherOrAdmin()
          || (hasRole('student') && request.resource.data.studentUid == request.auth.uid)
        );
      allow update: if hasAssignedActiveAccount()
        && (
          teacherOrAdmin()
          || (
            hasRole('student')
            && resource.data.studentUid == request.auth.uid
            && request.resource.data.studentUid == resource.data.studentUid
          )
        );
      allow delete: if teacherOrAdmin();
    }

    match /studentData/{studentUid}/{studentDocument=**} {
      allow read, write: if hasAssignedActiveAccount()
        && (teacherOrAdmin() || studentUid == request.auth.uid);
    }

    match /teacherData/{teacherDocument=**} {
      allow read, write: if teacherOrAdmin();
    }

    match /adminData/{adminDocument=**} {
      allow read, write: if hasRole('admin');
    }

    match /{document=**} {
      allow read, write: if hasRole('admin');
    }
  }
}
